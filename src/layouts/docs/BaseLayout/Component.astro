---
import type { TitleMetaLinkTag } from '@datocms/astro';
import { BaseLayout } from '~/layouts/BaseLayout';
import s from './style.module.css';
import { Svg } from '~/components/Svg';
import { Search } from '~/components/Search';
import { Feedback } from './Feedback';
import { TargetToggler } from '~/components/TargetToggler';
import LLMDate from '~/components/LLMDate/Component.astro';

type Props = {
  seo: TitleMetaLinkTag[];
  contentWrapperComponent?: (props: any) => any;
  lastUpdatedAt?: string;
};

const { seo, contentWrapperComponent, lastUpdatedAt } = Astro.props;
const ContentWrapper = contentWrapperComponent || 'div';
---

<BaseLayout seo={seo}>
  <slot name="head" slot="head" />

  <docs-sidebar-drawer>
    <div class={s.root} data-drawer-root>
      <div class={s.sidebar}>
        <div class={s.sidebarHeader}>
          <a href="/" class={s.logo}>
            <Svg name="svg/datocms/icon-text/color/color_full_logo" height={30} />
          </a>
          <TargetToggler targetId="sidebar">
            <button type="button" class={s.hamburger} aria-label="Toggle navigation menu">
              <span class={s.iconBars}><Svg name="icons/regular/bars" /></span>
              <span class={s.iconTimes}><Svg name="icons/regular/xmark" /></span>
              <span class={s.hamburgerBadge} aria-hidden="true">
                <Svg name="svg/datocms/icon/color/color_d_icon" />
              </span>
            </button>
          </TargetToggler>
          <div class={s.mobileSearch}>
            <Search client:idle variant="docs" />
          </div>
        </div>
        <aside class={s.innerSidebar} data-datocms-noindex id="sidebar">
          <div class={s.drawerHeader}>
            <div class={s.drawerBranding}>
              <Svg name="svg/datocms/icon/color/color_d_icon" height={24} />
              <span class={s.drawerTitle}>DatoCMS Docs</span>
            </div>
            <button
              type="button"
              class={s.drawerClose}
              data-sidebar-close
              aria-label="Close navigation menu"
            >
              <Svg name="icons/regular/xmark" />
            </button>
          </div>
          <div class={s.drawerNav}>
            <slot name="sidebar" />
          </div>
        </aside>
        <div class={s.backdrop} data-sidebar-backdrop></div>
      </div>
      <div class={s.contentWrapper} data-drawer-content>
        <div class={s.mainHeader}>
          <div class={s.desktopSearch}>
            <Search client:idle variant="docs" />
          </div>
          <ul>
            <li>
              <a href="/support">
                <Svg name="icons/regular/headset" />
                Ask for help!
              </a>
            </li>
            <li>
              <a href="https://status.datocms.com" target="_blank" rel="noreferrer">
                <Svg name="icons/regular/gauge-high" />
                Status page
              </a>
            </li>
          </ul>
        </div>
        <ContentWrapper>
          <div class={s.container} transition:animate="slide">
            <slot />
            {
              lastUpdatedAt && (
                <p class={s.lastUpdate}>
                  Last updated: <LLMDate date={lastUpdatedAt} />
                </p>
              )
            }
            <div class={s.footer} data-datocms-noindex>
              <div class={s.footerCol}>
                <div class={s.footerTitle}>Did this doc help you?</div>
                <div class={s.footerBody}>
                  <Feedback />
                </div>
              </div>
              <div class={s.footerCol}>
                <div class={s.footerTitle}>Need help?</div>
                <div class={s.footerBody}>
                  Explore our <a href="https://community.datocms.com">forum</a>,{' '}
                  <a href="/support">contact support</a>, or{' '}
                  <a href="/enterprise-headless-cms#form"> connect with our sales team </a>
                  . You can also chat live with other users in our{' '}
                  <a href="/slack">Slack channel</a>.
                </div>
              </div>
            </div>
          </div>
        </ContentWrapper>
      </div>
    </div>
  </docs-sidebar-drawer>

  <style is:global>
    docs-sidebar-drawer {
      display: contents;
    }
  </style>

  <script>
    import { WebComponent } from '~/lib/WebComponent';

    window.customElements.define(
      'docs-sidebar-drawer',
      class DocsSidebarDrawer extends WebComponent {
        root!: HTMLElement;
        content!: HTMLElement;
        sidebar!: HTMLElement;
        toggler!: HTMLElement;
        backdrop!: HTMLElement;
        closeBtn!: HTMLElement;

        parsedCallback() {
          this.root = this.$('[data-drawer-root]');
          this.content = this.$('[data-drawer-content]');
          this.sidebar = this.$('#sidebar');
          this.toggler = this.$('target-toggler');
          this.backdrop = this.$('[data-sidebar-backdrop]');
          this.closeBtn = this.$('[data-sidebar-close]');

          this.on(this.toggler, 'target-toggler:toggle', (event) => {
            if (event.target !== this.toggler) return;
            (event as CustomEvent).detail.expanded ? this.open() : this.close();
          });

          this.on(this.backdrop, 'click', () => this.toggle(false));
          this.on(this.closeBtn, 'click', () => this.toggle(false));

          this.on(this.sidebar, 'click', (event) => {
            const link = (event.target as HTMLElement).closest('a');
            if (link) this.toggle(false);
          });

          this.eventListenerRemovers.push(this.addEscapeListener());
        }

        addEscapeListener() {
          const handler = (event: KeyboardEvent) => {
            if (event.key === 'Escape' && this.root.hasAttribute('data-drawer-open')) {
              this.toggle(false);
            }
          };
          document.addEventListener('keydown', handler);
          return () => document.removeEventListener('keydown', handler);
        }

        toggle(expanded: boolean) {
          (this.toggler as any).toggle(expanded);
        }

        open() {
          this.root.setAttribute('data-drawer-open', '');
          document.body.style.overflow = 'hidden';
          this.content.setAttribute('inert', '');
          requestAnimationFrame(() => {
            this.closeBtn.focus();
            const active = this.sidebar.querySelector('[aria-current]');
            if (active) active.scrollIntoView({ block: 'nearest' });
          });
        }

        close() {
          this.root.removeAttribute('data-drawer-open');
          document.body.style.overflow = '';
          this.content.removeAttribute('inert');
          const btn = this.toggler.querySelector('button');
          if (btn) btn.focus();
        }
      },
    );
  </script>
</BaseLayout>
