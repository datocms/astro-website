---
import { Hero } from '~/components/Hero';
import { Layout } from '~/layouts/Layout';
import { LegalProse } from '~/components/LegalProse';
import privacy from '~/documents/privacy.json';
---

<Layout seo={[]}>
  <Fragment slot="head">
    <title>Privacy Policy</title>
  </Fragment>
  <Hero>
    <Fragment slot="kicker">Legal</Fragment>
    <Fragment slot="title"><mark>Privacy Policy</mark></Fragment>
  </Hero>
  <LegalProse>
    <Fragment set:html={privacy.content} />
  </LegalProse>
</Layout>

<script>
  document.querySelectorAll('details').forEach((el) => {
    el.addEventListener('click', (e) => {
      if ((e.target as Element).closest('summary, a, button, input, select, textarea')) return;
      e.preventDefault();
      el.open = !el.open;
    });
  });
</script>
