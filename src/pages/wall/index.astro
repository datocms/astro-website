---
import { render as toPlainText } from 'datocms-structured-text-to-plain-text';
import type { Review } from 'schema-dts';
import { Hero } from '~/components/Hero';
import { JsonLd } from '~/components/JsonLd';
import { Layout } from '~/layouts/Layout';
import { query } from './_graphql';
import { executeQuery } from '~/lib/datocms/executeQuery';
import { SingleQuote } from '~/components/quote/SingleQuote';
import s from './_style.module.css';
import { DraftModeQueryListener } from '~/components/DraftModeQueryListener';

const { allPartnerTestimonials, allReviews } = await executeQuery(Astro, query);

const quotes = [...allPartnerTestimonials, ...allReviews].sort((a, b) =>
  b._updatedAt.localeCompare(a._updatedAt),
);

const reviewsData: Review[] = quotes.map((item) => ({
  '@type': 'Review',
  itemReviewed: { '@type': 'SoftwareApplication', name: 'DatoCMS' },
  author: {
    '@type': 'Person' as const,
    name: item.name ?? undefined,
    ...(item.role ? { jobTitle: item.role } : {}),
    ...(item.__typename === 'PartnerTestimonialRecord' && item.partner
      ? { worksFor: { '@type': 'Organization' as const, name: item.partner.name } }
      : {}),
  },
  reviewBody: toPlainText(item.quote) || undefined,
}));
---

<Layout seo={[]}>
  <Fragment slot="head">
    <title>Better, with DatoCMS</title>
    <JsonLd data={{ '@context': 'https://schema.org', '@graph': reviewsData }} />
  </Fragment>

  <Hero>
    <Fragment slot="kicker">Customers</Fragment>

    <Fragment slot="title"><mark>Better</mark>, with DatoCMS</Fragment>
    <Fragment slot="subtitle">
      Hear from our customers about what changed for the better since they switched to DatoCMS
    </Fragment>
  </Hero>

  <div class={s.quotes}>
    {
      quotes.map((quote) => (
        <div class={s.quote}>
          <SingleQuote quote={quote} />
        </div>
      ))
    }
  </div>

  <DraftModeQueryListener query={query} />
</Layout>
