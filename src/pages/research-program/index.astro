---
import { executeQuery } from '~/lib/datocms/executeQuery';
import { notFoundResponse, avoidAstroTypeCheckBug } from '~/lib/notFoundResponse';
import { ensureValidStructuredTextProps, stripStega } from '@datocms/astro';
import { InlineText } from '~/components/structuredText/InlineText';
import { Text } from '~/components/structuredText/Text';
import { DraftModeQueryListener } from '~/components/DraftModeQueryListener';
import { query } from './_graphql';
import { Layout } from '~/layouts/Layout';
import { Hero } from '~/components/Hero';
import { Space } from '~/components/Space';
import { Prose } from '~/components/Prose';
import { InterstitialTitle } from '~/components/InterstitialTitle';
import { Wrapper } from '~/components/Wrapper';
import { Button } from '~/components/Button';
import { Journey, Step } from '~/components/Journey';
import { Faqs, Faq } from '~/components/Faqs';

const { page } = await executeQuery(Astro, query);

if (!page) {
  avoidAstroTypeCheckBug(notFoundResponse);
  return notFoundResponse();
}
---

<Layout seo={page.seo} noFinalCta>
  <Hero seoAnalysis={{ keyword: 'research', synonyms: '', relatedKeywords: [] }}>
    <Fragment slot="kicker">{page.heroKicker}</Fragment>
    <Fragment slot="title">
      <InlineText {...ensureValidStructuredTextProps({ data: page.heroTitle })} />
    </Fragment>
    <Fragment slot="subtitle">{page.heroSubtitle}</Fragment>
    <Space top={1}>
      <Button as="a" href={stripStega(page.heroCtaUrl)}>{page.heroCtaLabel}</Button>
    </Space>
  </Hero>

  <Space top={3} bottom={2}>
    <InterstitialTitle style="two">
      {page.journeyTitle}

      <Fragment slot="below">
        <Space top={1}>{page.journeySubtitle}</Space>
      </Fragment>
    </InterstitialTitle>

    <Wrapper>
      <Journey>
        <Step number="01" title={page.step1Title ?? ''}>{page.step1Body}</Step>
        <Step number="02" title={page.step2Title ?? ''}>{page.step2Body}</Step>
        <Step number="03" title={page.step3Title ?? ''}>{page.step3Body}</Step>
      </Journey>
    </Wrapper>
  </Space>

  <Space top={3}>
    <InterstitialTitle>{page.faqSectionTitle}</InterstitialTitle>
    <Wrapper>
      <Faqs>
        {
          page.faqs.map((faq) => (
            <Faq question={faq.question}>
              <Prose>
                <Text {...ensureValidStructuredTextProps({ data: faq.answer })} />
              </Prose>
            </Faq>
          ))
        }
      </Faqs>
    </Wrapper>
  </Space>

  <Space top={2} bottom={2}>
    <InterstitialTitle style="two">
      <InlineText {...ensureValidStructuredTextProps({ data: page.bottomCtaTitle })} />

      <Fragment slot="below">
        <Space top={1}>{page.bottomCtaBody}</Space>
        <Space top={1}>
          <Button as="a" href={stripStega(page.bottomCtaButtonUrl)} p="big" fs="big">
            {page.bottomCtaButtonLabel}
          </Button>
        </Space>
      </Fragment>
    </InterstitialTitle>
  </Space>

  <DraftModeQueryListener query={query} />
</Layout>
