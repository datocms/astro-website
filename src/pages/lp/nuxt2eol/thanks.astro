---
import { LpLayout } from '~/layouts/lp';
import s from './_thanks.module.css';
---

<LpLayout
  title="Assessment booked — DatoCMS & De Voorhoede"
  partner={{
    name: 'De Voorhoede',
    logoUrl:
      'https://www.datocms-assets.com/205/1649929882-logo-on-transparent-without-padding.svg',
    siteUrl: 'https://www.devoorhoede.nl',
  }}
>
  <section class={s.section}>
    <div class={s.inner}>
      <div class={s.emoji}>🎉</div>
      <h1 class={s.title}>You're all set. We'll be in touch soon.</h1>
      <p class={s.body}>
        Both the De Voorhoede and DatoCMS teams have received your request. Expect to hear from us
        soon to schedule your free migration assessment.
      </p>
      <a href="/" class={s.cta}>Explore DatoCMS while you wait →</a>
    </div>
  </section>
</LpLayout>
