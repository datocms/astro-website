---
import { LpLayout } from '~/layouts/lp';
import s from './_thanks.module.css';
---

<LpLayout title="Request received — DatoCMS">
  <section class={s.section}>
    <div class={s.inner}>
      <div class={s.emoji}>✅</div>
      <h1 class={s.title}>We've got your request.</h1>
      <p class={s.body}>
        The DatoCMS team has received your details. Expect to hear from us shortly to schedule your
        migration conversation.
      </p>
      <a href="/" class={s.cta}>Explore DatoCMS while you wait →</a>
    </div>
  </section>
</LpLayout>
