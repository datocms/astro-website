---
import { FormResultLayout } from '~/layouts/FormResultLayout';

const GADS_CONVERSION = 'AW-11079629404/vEIuCKqAqrAcENz0lqMp';
---

<FormResultLayout type="success" kicker="Agency Partner Program">
  <script is:inline define:vars={{ GADS_CONVERSION }}>
    window.dataLayer = window.dataLayer || [];
    function gtag() {
      dataLayer.push(arguments);
    }
    gtag('event', 'conversion', { send_to: GADS_CONVERSION });
  </script>
  <p>
    We have successfully received your request, and <strong
      >you will soon receive an automated confirmation via email</strong
    >.
  </p>
  <p>
    We look forward to meeting you soon, learning more about your agency, and sharing the philosophy
    of our Partner Program.
  </p>
  <p>See you very soon!</p>
</FormResultLayout>
